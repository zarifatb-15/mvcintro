@model List<CarModel>

@{
    if (Model.Count == 0)
    {
        <h1>BELE BIR MODEL TAPILMADI</h1>
    }
    else
    {
        <ul>
            @foreach (var carModel in Model)
            {
                <li>
                    <a href="/car/index?carModelId=@carModel.Id">@carModel.Name</a>
                </li>
            }
        </ul>
    }
}
